# scintilla environment configuration
#
# Copy this file to `.env` and edit as needed. `.env` is gitignored — your
# real credentials will not be committed.

# Path to the data directory. Defaults to `./data` (the demo subset shipped
# with the repo). For real work, point this at a larger directory where
# raw GLM/ISS LIS granules and clipped chips will live.
SCINTILLA_DATA_DIR=./data

# Stadia Maps API token for branded basemap tiles (optional).
# Get one free at https://client.stadiamaps.com/
STADIA_API_TOKEN=
